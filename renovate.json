{
    "lockFileMaintenance": {
        "enabled": true,
        "automerge": true
    },
    "packageRules": [
        {
            "matchDepTypes": [
                "dependencies",
                "devDependencies"
            ],
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "automerge": true,
            "automergeType": "branch"
        }
    ],
    "platformAutomerge": true,
    "automergeStrategy": "merge-commit"
}
